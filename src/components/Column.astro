---
interface Props {
  title: string;
  status: string;
}

const { title, status } = Astro.props;
---

<section class="column">
  <div class="column-header">
    <h2>{title}</h2>
    <span class="task-count" data-count-status={status}>0</span>
  </div>

  <div class="task-list" data-status={status}></div>

  <button class="add-task-btn" data-status={status}>+ Add Task</button>
</section>

<style>
  .column {
    background-color: var(--color-column-bg);
    border-radius: var(--radius-lg);
    padding: var(--spacing-md);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    max-height: calc(100vh - 140px);
    overflow-y: auto;
  }

  .column-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: var(--spacing-sm);
  }

  .column-header h2 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .task-count {
    background-color: rgba(0, 0, 0, 0.1);
    color: var(--color-text-secondary);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 10px;
    min-width: 1.5rem;
    text-align: center;
  }

  .task-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    min-height: 80px;
    flex: 1;
    padding: var(--spacing-xs);
    border-radius: var(--radius-md);
    transition: background-color var(--transition-fast), border-color var(--transition-fast);
    border: 2px solid transparent;
  }

  .add-task-btn {
    background: none;
    border: none;
    border-radius: var(--radius-md);
    padding: var(--spacing-sm) var(--spacing-md);
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    cursor: pointer;
    text-align: left;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .add-task-btn:hover {
    background-color: rgba(0, 0, 0, 0.06);
    color: var(--color-text);
  }
</style>
