---
/**
 * ============================================================
 *  Owner: Carlos (Interaction Layer)
 *  File: Task Form modal (used for both Add and Edit)
 * ============================================================
 *
 *  【What to do】
 *  Build a modal with a form to create or edit a task.
 *  The same modal is reused for both "Add" and "Edit" modes.
 *
 *  1. Import the Modal component
 *
 *  2. Wrap content inside <Modal id="task-form-modal">
 *
 *  3. Build a form with these fields:
 *     - Title input     (id="form-task-title", required)
 *     - Description textarea (id="form-task-description")
 *     - Due date input  (id="form-task-due-date", type="date")
 *     - A hidden input to track if editing (id="form-task-id", type="hidden")
 *
 *  4. Add a submit button:
 *     - Text changes based on mode: "Add Task" or "Save Changes"
 *     (modal.ts will handle switching the text and form behavior)
 *
 *  5. Add a heading that changes based on mode:
 *     - <h2 id="form-modal-title">Add New Task</h2>
 *     (modal.ts will switch this to "Edit Task" when editing)
 *
 *  【Form submission】
 *  - Carlos: handle the submit event in modal.ts
 *  - On submit, call Suzuna's KanbanBoard methods:
 *    → Add mode: board.taskList.add(title, description, dueDate)
 *    → Edit mode: board.taskList.update(id, { title, description, dueDate })
 *  - Then call board.save() and re-render the board
 * ============================================================
 */

import Modal from "./Modal.astro";
---

<!-- TODO: Carlos - Build the task form modal here -->
<Modal id="task-form-modal">
  <h2 id="form-modal-title">Add New Task</h2>

  <form id="task-form">
    <input type="hidden" id="form-task-id" />

    <label for="form-task-title">Title</label>
    <input type="text" id="form-task-title" required />

    <label for="form-task-description">Description</label>
    <textarea id="form-task-description"></textarea>

    <label for="form-task-due-date">Due Date</label>
    <input type="date" id="form-task-due-date" />

    <button type="submit" id="form-submit-btn">Add Task</button>
  </form>
</Modal>
