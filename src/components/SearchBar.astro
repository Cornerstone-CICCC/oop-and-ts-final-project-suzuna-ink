---
/**
 * ============================================================
 *  Owner: Carlos (Interaction Layer)
 *  File: SearchBar component with auto-complete
 * ============================================================
 *
 *  【What to do】
 *  Build a search bar that filters tasks by name with auto-completion.
 *
 *  1. Render:
 *     - A text input (id="search-input", placeholder="Search tasks...")
 *     - A results dropdown list (id="search-results", hidden by default)
 *
 *  2. The dropdown shows matching task titles as the user types
 *     → Logic is handled in search.ts
 *
 *  3. Clicking a result opens the View Task modal for that task
 *     → search.ts calls the modal open function
 *
 *  【HTML structure suggestion】
 *  <div class="search-bar">
 *    <input type="text" id="search-input" placeholder="Search tasks..." />
 *    <ul id="search-results" class="search-results"></ul>
 *  </div>
 *
 *  【How search works (implemented in search.ts)】
 *  - On each keystroke, call Suzuna's taskList.searchByName(query)
 *  - Render matching tasks as <li> items in the dropdown
 *  - On click, open the ViewTaskModal with that task's data
 *  - Hide dropdown when input is empty or loses focus
 * ============================================================
 */
---

<!-- TODO: Carlos - Build the search bar HTML here -->
<div class="search-bar">
  <input type="text" id="search-input" placeholder="Search tasks..." autocomplete="off" />
  <ul id="search-results" class="search-results"></ul>
</div>

<style is:global>
  /* TODO: Carlos - Style the search bar and dropdown */
  .search-bar {
    position: relative;
    width: 100%;
    max-width: 400px;
    margin: 20px auto;
  }

  #search-input {
    width: 100%;
    padding: 12px 16px;
    font-size: 14px;
    border: 1px solid #ddd;
    border-radius: 8px;
    outline: none;
    transition: all 0.2s ease;
    box-shadow: 0 2px 6px rgba(0,0,0,0.05);
  }

  #search-input::placeholder {
    color: #aaa;
  }

  #search-input:focus {
    border-color: #4f46e5;
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.15);
  }

  .search-results {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  width: 100%;

  list-style: none;
  padding: 0 ; 
  margin: 0; 

  background: white;
  border-radius: 10px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.08);
  max-height: 200px;
  overflow-y: auto;
  display: none;
  z-index: 100;
}

.search-results li {
  list-style: none;
  padding: 10px 16px;
  cursor: pointer;
  font-size: 14px;
  transition: background 0.15s ease;
}
.search-results li:hover {
  background-color: lightgray;
}
</style>
